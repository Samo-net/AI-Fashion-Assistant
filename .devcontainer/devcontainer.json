{
  "name": "AI Fashion Assistant",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/docker-in-docker:2": { "version": "latest" }
  },
  "forwardPorts": [8000, 8081, 5432],
  "portsAttributes": {
    "8000": { "label": "FastAPI Backend", "onAutoForward": "notify" },
    "8081": { "label": "Expo Dev Server", "onAutoForward": "notify" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "ms-python.isort",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "[python]": {
          "editor.formatOnSave": true
        }
      }
    }
  }
}
