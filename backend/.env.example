# ── App ────────────────────────────────────────────────────────────────────
APP_NAME="AI Fashion Assistant"
DEBUG=true

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fashionuser:fashionpass@localhost:5432/fashiondb

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Firebase ────────────────────────────────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── AWS S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_BUCKET_NAME=ai-fashion-assistant
AWS_REGION=us-east-1

# ── OpenAI ────────────────────────────────────────────────────────────────
# Use gpt-4o-mini for dev; switch to gpt-4o for final evaluation
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Replicate (Stable Diffusion during development) ───────────────────────
REPLICATE_API_TOKEN=r8_...

# ── OpenWeatherMap ────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_key_here
